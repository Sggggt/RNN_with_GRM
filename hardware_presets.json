{
  "description": "Hardware-aware presets for the active segment-memory training stack.",
  "version": "3.1",
  "changelog": [
    "v3.1: renamed preset keys to the academic terminology used by the current codebase.",
    "v3.0: introduced balanced recomputation ratios instead of full recomputation.",
    "v2.0: added memory-optimization controls for low-VRAM execution."
  ],
  "memory_optimization": {
    "description": "Recommended defaults for memory pressure and numerical storage.",
    "recomputation_ratio": {
      "description": "Fraction of retrieved routes re-evaluated from checkpoints instead of using archived matrices.",
      "recommended": 0.02,
      "low_vram": 0.0,
      "balanced": 0.02,
      "high_quality": 0.05
    },
    "enable_activation_checkpointing": {
      "description": "Toggle activation checkpointing for long-context training.",
      "recommended": false,
      "low_vram": true
    },
    "memory_storage_dtype": {
      "description": "Numerical precision used to archive segment memories.",
      "recommended": "float16",
      "alternatives": ["bfloat16", "float32"]
    }
  },
